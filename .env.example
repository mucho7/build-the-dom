# 기상청 API 허브에서 발급한 동네예보 API 인증키를 입력합니다.
KMA_AUTH_KEY=

# 공공데이터포털에서 발급한 기상청 지상(종관, ASOS) 시간자료 조회서비스 인증키입니다.
# 과거 3년 경기의 실제 강수 관측값을 수집할 때만 필요합니다.
KMA_ASOS_SERVICE_KEY=

# PostgreSQL 연결 문자열을 입력합니다. Neon, Supabase 또는 로컬 PostgreSQL을 사용할 수 있습니다.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rainout?schema=public

# 시간 단위 예보 캐시 배치를 실행할 때 사용하는 비밀값입니다.
CRON_SECRET=
